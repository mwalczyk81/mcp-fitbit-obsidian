# ─── Fitbit OAuth credentials ─────────────────────────────────────────────────
# Create your app at https://dev.fitbit.com/apps/new
#   • OAuth 2.0 Application Type: Personal
#   • Callback URL: http://localhost:8080
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# ─── Obsidian vault ────────────────────────────────────────────────────────────
# Absolute path to the root of your vault.
# Daily notes must live at {VAULT_DIR}/01 - Daily Notes/YYYY-MM-DD.md
VAULT_DIR=C:/Users/yourname/Documents/Obsidian/YourVault

# ─── OAuth redirect URI ────────────────────────────────────────────────────────
# Must exactly match the Callback URL registered in your Fitbit app.
REDIRECT_URI=http://localhost:8080

# Required so the OAuth library accepts an http:// (non-TLS) redirect URI.
OAUTHLIB_INSECURE_TRANSPORT=1

# ─── MCP transport ─────────────────────────────────────────────────────────────
# stdio  — Claude Desktop / Cowork (default)
# sse    — Claude.ai via Cloudflare Tunnel
MCP_TRANSPORT=stdio

# Port used when MCP_TRANSPORT=sse (default 8765)
MCP_PORT=8765

# ─── Token file ────────────────────────────────────────────────────────────────
# Path to the JSON file where OAuth tokens are stored after running `uv run auth`.
# Defaults to fitbit_tokens.json in the project root.
# TOKEN_FILE=fitbit_tokens.json
